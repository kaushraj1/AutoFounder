{
  "name": "autofounder-ai-enterprise",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo dev",
    "lint": "turbo lint && uv run --directory apps/api ruff check src && uv run --directory apps/api ruff format --check src",
    "lint:js": "turbo lint",
    "lint:backend": "uv run --directory apps/api ruff check src",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0"
  }
}
