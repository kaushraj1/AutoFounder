# Copy to `.env` for local development. Do not commit real secrets.
#   cp .env.example .env

# --- PostgreSQL (docker-compose) ---
POSTGRES_USER=autofounder-ai
POSTGRES_PASSWORD=autofounder-ai_local
POSTGRES_DB=autofounder-ai
POSTGRES_PORT=5432

# App connection string (API/worker — used when backend is implemented)
DATABASE_URL=

# --- Redis (optional local cache / rate-limit / session experiments) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Vercel (CI/CD — used in GitHub Actions, not locally) ---
# Do NOT put real values here. Add these as GitHub repository secrets instead.
# See frontend-web/DEPLOYMENT.md for how to obtain each value.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=