# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
LOG_LEVEL=INFO                               # DEBUG | INFO | WARN | ERROR
SECRET_KEY=                                  # FastAPI secret key (32+ random bytes)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Local: run `supabase start` — values printed automatically
# Hosted: from Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=postgresql://postgres:<password>@db.<your-project-ref>.supabase.co:5432/postgres

# ─── Frontend (Next.js 14) — must be prefixed NEXT_PUBLIC_ ───────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/v1
NEXT_PUBLIC_SENTRY_DSN=

# ─── Mobile (Expo) — must be prefixed EXPO_PUBLIC_ ───────────────────────────
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_URL=http://localhost:8000/v1
EXPO_PUBLIC_EAS_PROJECT_ID=                  # from `eas init`

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local: started via `make stack` (docker compose up -d)
# Production: AWS ElastiCache — injected from Secrets Manager
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=                              # leave blank for local Docker

# ─── Gemini (Primary LLM + Embeddings) ───────────────────────────────────────
# All agent task classes use Gemini 3.5 Flash; gemini-embedding-2 for all vectors
GEMINI_API_KEY=

# ─── OpenAI (DALL-E 3 image gen + Whisper speech transcription) ──────────────
OPENAI_API_KEY=

# ─── Cohere (RAG reranker) ────────────────────────────────────────────────────
COHERE_API_KEY=

# ─── LiteLLM (Model Router) ───────────────────────────────────────────────────
LITELLM_DEFAULT_MODEL=gemini/gemini-2.5-flash
LITELLM_EMBEDDING_MODEL=gemini/text-embedding-004

# ─── LangSmith (LLM tracing + evals) ─────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=autofounder-ai-dev         # project name in LangSmith dashboard
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─── Sentry (Error tracking) ──────────────────────────────────────────────────
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
SENTRY_ENVIRONMENT=development

# ─── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=autofounder-ai-api
OTEL_RESOURCE_ATTRIBUTES=env=development,project=autofounder-ai

# ─── AWS Core ─────────────────────────────────────────────────────────────────
# Local dev: use a dev IAM user with least-privilege policy
# Production: ECS task role (no access keys needed in prod)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_S3_ARTIFACTS_BUCKET=autofounder-ai-artifacts-dev
AWS_S3_DATALAKE_BUCKET=autofounder-ai-datalake-dev
AWS_S3_PROMPTS_BUCKET=autofounder-ai-prompts-dev
AWS_S3_AUDIT_BUCKET=autofounder-ai-audit-dev

# ─── AWS ECR ──────────────────────────────────────────────────────────────────
AWS_ECR_REGISTRY=                            # e.g. 123456789.dkr.ecr.ap-south-1.amazonaws.com

# ─── AWS SQS (per-pillar work queues) ─────────────────────────────────────────
AWS_SQS_PILLAR1_QUEUE_URL=
AWS_SQS_PILLAR2_QUEUE_URL=
AWS_SQS_PILLAR3_QUEUE_URL=
AWS_SQS_PILLAR4_QUEUE_URL=
AWS_SQS_PILLAR5_QUEUE_URL=
AWS_SQS_PILLAR6_QUEUE_URL=
AWS_SQS_PILLAR7_QUEUE_URL=
AWS_SQS_DLQ_URL=

# ─── AWS SNS (fan-out / push notifications) ───────────────────────────────────
AWS_SNS_PUSH_TOPIC_ARN=
AWS_SNS_ALERTS_TOPIC_ARN=

# ─── AWS EventBridge ──────────────────────────────────────────────────────────
AWS_EVENTBRIDGE_BUS_NAME=autofounder-ai-dev

# ─── Confluent Kafka (primary inter-agent event bus) ─────────────────────────
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_API_KEY=
KAFKA_API_SECRET=
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SCHEMA_REGISTRY_URL=
KAFKA_SR_API_KEY=
KAFKA_SR_API_SECRET=

# ─── Neo4j (Graph DB — competitor ↔ market ↔ persona) ────────────────────────
# Production choice pending benchmark (Neo4j AuraDB vs Amazon Neptune)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ─── Stripe (Payments + Billing) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_SOLOPRENEUR=                 # ₹10,000/mo plan price ID
STRIPE_PRICE_ID_STARTUP=                     # ₹50,000/mo plan price ID
STRIPE_PUBLISHABLE_KEY=                      # used by frontend checkout

# ─── Resend (Transactional Email) ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@mail.autofounder.ai

# ─── Expo Push Notifications ──────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=                           # from expo.dev account settings

# ─── GitHub App (Coder + Reviewer agents) ─────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=                      # PEM key — newlines as \n
GITHUB_WEBHOOK_SECRET=

# ─── Research Tools (Strategy + Research agents) ──────────────────────────────
TAVILY_API_KEY=
SERPAPI_API_KEY=
CRUNCHBASE_API_KEY=
G2_API_KEY=
SIMILARWEB_API_KEY=

# ─── Marketing Platforms (Marketing agent — Launch Control Center) ─────────────
# Nothing publishes without founder HITL approval
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
LINKEDIN_ACCESS_TOKEN=
PRODUCTHUNT_API_KEY=

# ─── OPA (Policy Engine — Guardrails Stage 1) ─────────────────────────────────
OPA_URL=http://localhost:8181

# ─── Guardrails — Llama Guard + Presidio ─────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://localhost:5001
PRESIDIO_ANONYMIZER_URL=http://localhost:5002

# ─── Prometheus + Grafana (Metrics) ───────────────────────────────────────────
PROMETHEUS_REMOTE_WRITE_URL=
GRAFANA_URL=http://localhost:3000

# ─── AWS Step Functions (LLMOps weekly cycle) ─────────────────────────────────
AWS_STEPFUNCTIONS_LLMOPS_ARN=