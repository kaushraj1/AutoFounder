# ══════════════════════════════════════════════════════════════════════════════
# backend — Environment Variables
# Copy to `.env` for local development. Never commit a filled .env.
# Production secrets come from AWS Secrets Manager and are injected at runtime.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                  # development | staging | production
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-prod         # 32+ random bytes in real environments
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Database (Supabase local: `supabase start`) ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# ─── Redis (docker compose up -d) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Optional integrations (enable when the feature is built) ────────────────
# GEMINI_API_KEY=
# LANGSMITH_API_KEY=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Guardrails (AF-046) — 6-stage safety pipeline ───────────────────────────
# All optional: every stage degrades to a regex/heuristic/lexicon fallback when
# its external service is unset (Presidio, Llama Guard, OPA sidecar, TruLens).
# GUARDRAILS_ENABLED=true                    # master switch (default on)
# GUARDRAIL_BLOCK_ON_AUDIT_FAILURE=false     # prod-only fail-closed on audit write
# GUARDRAIL_TOOL_COST_CAP_USD=               # default per-tenant tool spend cap (USD)
# AWS_S3_AUDIT_BUCKET=                        # S3 Object Lock immutable lineage (7-yr)
# LLAMA_GUARD_ENDPOINT=                       # hosted injection/safety classifier
# PROMPT_ARMOR_KEY=                           # injection-defense API
# POSTHOG_KEY=                                # abuse/anomaly analytics
# OPA_URL=http://localhost:8181              # policy sidecar (dev-bypasses when offline)

# ─── Pillar 4 — Reviewer / Self-Healer Agent (AF-042) ────────────────────────
# All optional: each scanner/integration degrades to a non-fatal skip when unset.
# REVIEWER_MODEL=gemini-2.5-flash
# SEMGREP_APP_TOKEN=                  # Semgrep cloud SAST (else local CLI / skip)
# SNYK_TOKEN=                         # Snyk dependency scan (skipped if unset)
# SONARQUBE_URL=                      # SonarQube quality gate (skipped if unset)
# SONARQUBE_TOKEN=
# SONARQUBE_PROJECT_KEY=
# GITHUB_TOKEN=                       # PR comments + heal commits (else local-only)
# SLACK_WEBHOOK_REVIEWER=             # escalation alerts (skipped if unset)
# AWS_S3_ARTIFACTS_BUCKET=            # review report + scan JSON storage

# ─── Pillar 6 — Marketing & Launch Automation Agent (AF-044) ─────────────────
# Core LLM + image generation (shared with other pillars; reuse if already set)
# GEMINI_API_KEY=                     # Gemini 3.5 Flash — all LLM generation
# OPENAI_API_KEY=                     # DALL-E 3 — visual asset generation
# TAVILY_API_KEY=                     # Tavily web search — brand/competitor research

# Publishing + scheduling (all optional; content stored as "draft" if unset)
# BUFFER_ACCESS_TOKEN=                # Buffer — LinkedIn post scheduling
# BUFFER_PROFILE_ID=                  # Buffer profile ID for the LinkedIn account
# TYPEFULLY_API_KEY=                  # Typefully — X/Twitter thread scheduling
# RESEND_API_KEY=                     # Resend — transactional + drip email
# RESEND_FROM_ADDRESS=noreply@mail.autofounder.ai

# SEO keyword research (optional; falls back to LLM knowledge if unset)
# AHREFS_API_KEY=                     # Ahrefs keyword volume/difficulty data

# Alerts (optional; Slack alert sent on agent errors)
# SLACK_WEBHOOK_MARKETER=             # Slack incoming webhook for error alerts

# Phase 2: marketer_output.proto compilation deferred until AF-049 LLMOps lands.
# Proto definition: backend/app/agents/marketing/proto/marketer_output.proto
