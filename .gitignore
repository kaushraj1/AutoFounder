# ─── VS Code Extension ────────────────────────────────────────────────────────
*.vsix
vscode-extension/out/
vscode-extension/.vscode-test/

# The extension ships its own debug config (.vscode/launch.json + tasks.json).
# The IDE section's `.vscode/` rule ignores it and the root re-includes above are
# path-anchored (root-only), so re-include the extension's .vscode explicitly.
!vscode-extension/.vscode/
!vscode-extension/.vscode/**

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.tgz
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
# Local terraform validation log (transient output of scripts/tf-validate.ps1)
scripts/tf-validate.out
# Scratch commit-message drafts
.git-commit-msg.tmp
.git-commit-msg*.tmp
