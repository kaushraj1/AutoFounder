# ─── Turbo / Monorepo ─────────────────────────────────────────────────────────
.turbo/

# ─── Docker ───────────────────────────────────────────────────────────────────
# (.dockerignore files ARE committed — do not ignore them)

# ─── Terraform / IaC ──────────────────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# The Terraform 'secrets' MODULE is infra-as-code (KMS + Secrets Manager resource
# DEFINITIONS, never secret values) — re-include it despite the broad `secrets/`
# ignore in the Environment & Secrets section above.
!infra/terraform/modules/secrets/
!infra/terraform/modules/secrets/**

# Re-include the Terraform per-environment inputs (CIDRs, node types, service
# config, backend bucket/key — NO secret values). The broad `env/`/`ENV/` venv
# ignore above otherwise swallows infra/terraform/env/.
!infra/terraform/env/
!infra/terraform/env/**

