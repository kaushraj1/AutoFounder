# Controls what is EXCLUDED from the packaged .vsix (separate from .gitignore).
# Everything is included by default; we ship only the bundled dist/ + media + docs.

.vscode/**
.vscode-test/**
.turbo/**
src/**
dist/test/**
node_modules/**

esbuild.mjs
tsconfig.json
eslint.config.*
.eslintcache
.gitignore
.npmrc

**/*.map
**/*.ts
**/tsconfig.json
**/.eslintrc*

# Keep: dist/extension.js, media/**, package.json, README.md, CHANGELOG.md, LICENSE
